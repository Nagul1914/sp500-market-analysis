{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["# S&P 500 Data Collection & Analysis\n", "**Author:** Nagul Meera Shaik | Data Analyst\n", "\n", "This notebook downloads live S&P 500 market data using the yfinance API,\n", "computes moving averages, detects golden cross signals, and prepares data for Power BI."]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import yfinance as yf\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Download S&P 500 + top stocks\n",
    "tickers = ['^GSPC', 'AAPL', 'MSFT', 'AMZN', 'GOOGL', 'NVDA', 'META', 'JPM', 'V', 'UNH']\n",
    "data = yf.download(tickers, start='2019-01-01', end='2024-12-31')\n",
    "df = data['Close'].reset_index()\n",
    "print(f'Downloaded {len(df)} rows of data')\n",
    "print(df.head())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Compute Moving Averages\n",
    "sp500 = yf.download('^GSPC', start='2019-01-01', end='2024-12-31')['Close'].reset_index()\n",
    "sp500.columns = ['Date', 'Close']\n",
    "sp500['SMA_50']  = sp500['Close'].rolling(50).mean()\n",
    "sp500['SMA_200'] = sp500['Close'].rolling(200).mean()\n",
    "sp500['Daily_Return'] = sp500['Close'].pct_change() * 100\n",
    "\n",
    "# Detect Golden Cross\n",
    "sp500['Golden_Cross'] = (\n",
    "    (sp500['SMA_50'] > sp500['SMA_200']) &\n",
    "    (sp500['SMA_50'].shift(1) <= sp500['SMA_200'].shift(1))\n",
    ")\n",
    "print(f'Golden Cross signals found: {sp500[\"Golden_Cross\"].sum()}')\n",
    "sp500.to_csv('../data/sp500_processed.csv', index=False)\n",
    "print('Data saved to data/sp500_processed.csv')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualization\n",
    "plt.figure(figsize=(14, 6))\n",
    "plt.plot(sp500['Date'], sp500['Close'],   label='S&P 500 Close', linewidth=1.5, color='#63D2FF')\n",
    "plt.plot(sp500['Date'], sp500['SMA_50'],  label='SMA 50',  linewidth=1.2, color='#FFD166')\n",
    "plt.plot(sp500['Date'], sp500['SMA_200'], label='SMA 200', linewidth=1.2, color='#FF7B7B')\n",
    "gc = sp500[sp500['Golden_Cross']]\n",
    "plt.scatter(gc['Date'], gc['Close'], color='#7BF5A0', s=100, zorder=5, label='Golden Cross')\n",
    "plt.title('S&P 500 — Price Trend with Moving Averages', fontsize=14, fontweight='bold')\n",
    "plt.xlabel('Date'); plt.ylabel('Price (USD)')\n",
    "plt.legend(); plt.tight_layout()\n",
    "plt.savefig('../reports/sp500_trend_chart.png', dpi=150)\n",
    "plt.show()\n",
    "print('Chart saved to reports/')"
   ]
  }
 ],
